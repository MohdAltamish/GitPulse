# GitPulse Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ALL of these are optional. GitPulse degrades gracefully:
#   - No ANTHROPIC_API_KEY  -> runs the four tools deterministically (no LLM).
#   - No GITLAB_TOKEN        -> falls back to real static import analysis, then mock.

# Anthropic API key (OPTIONAL). When set, the Claude agent drives the tool
# calls. When absent, GitPulse runs the same tools deterministically.
ANTHROPIC_API_KEY=

# GitLab personal access token (needed for real Orbit graph + MR comments).
# Scope needed: api. Sent to the Orbit REST API as the PRIVATE-TOKEN header.
# In CI, CI_JOB_TOKEN is used automatically if this is unset.
GITLAB_TOKEN=

# Default GitLab project ID (can also pass via --project-id flag).
GITLAB_PROJECT_ID=

# GitLab API v4 base URL (OPTIONAL — defaults to https://gitlab.com/api/v4).
# In CI, CI_API_V4_URL is used automatically.
GITLAB_API_URL=
