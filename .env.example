# GitPulse Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API key (required for the Claude agent)
ANTHROPIC_API_KEY=

# GitLab personal access token (required for real API calls)
# Scopes needed: read_api, read_repository
# For posting MR comments (--comment), an `api`-scoped token is required.
GITLAB_TOKEN=

# Default GitLab project ID (can also pass via --project-id flag)
GITLAB_PROJECT_ID=

# Orbit API base URL (optional — defaults to https://gitlab.com/-/orbit/api/v1)
ORBIT_API_URL=
